rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "narenaiims@gmail.com" && 
        request.auth.token.email_verified == true
      );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user is a member of the group
    function isGroupMember(groupId) {
      return isAuthenticated() && (
        isAdmin() || 
        exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
      );
    }

    // Check if the user is an admin in the group
    function isGroupAdmin(groupId) {
      return isAuthenticated() && (
        isAdmin() || 
        get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // Wish Templates
      match /templates/{templateId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Shared Groups
    match /groups/{groupId} {
      // Allow reading the group document if you are a member
      allow read: if isGroupMember(groupId);
      allow create: if isAuthenticated();
      allow update, delete: if isGroupAdmin(groupId);

      // Group Members and Roles
      match /members/{memberId} {
        // Allow reading if you are a member of the group OR if you are the member being read (for collectionGroup queries)
        allow read: if isGroupMember(groupId) || isOwner(memberId);
        
        // Allow joining a group if you are authenticated (the app uses invite links to share the ID)
        // Or if you are an admin adding someone
        allow create: if isAuthenticated() && (
          isOwner(memberId) || isGroupAdmin(groupId)
        );
        
        allow update, delete: if isGroupAdmin(groupId);
      }

      // Birthdays in the Group
      match /birthdays/{birthdayId} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isGroupMember(groupId); // Allow members to add birthdays, not just admins? 
        // The app UI seems to allow members to add birthdays. Let's check.
      }
    }

    // Allow collectionGroup queries on members
    match /{path=**}/members/{memberId} {
      allow read: if isAuthenticated() && (request.auth.uid == memberId || (resource != null && request.auth.uid == resource.data.uid));
    }

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Group Invites
    match /invites/{token} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isGroupAdmin(request.resource.data.groupId);
      allow delete: if isAuthenticated() && isGroupAdmin(resource.data.groupId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
